        "mode": "runOnceForEachItem",
        "jsCode": "const src = $('Extraire texte').item.json;\nif (!src || !src.record_id) return null;\n\nlet ai = {};\ntry {\n  const raw = String($json.output || $json.text || '{}').trim();\n  const m = raw.match(/\\{[\\s\\S]*\\}/);\n  if (m) ai = JSON.parse(m[0]);\n} catch(e) {}\n\nconst runDate = $('Config').first().json.run_date;\nconst fields = { id: src.record_id };\n\nif (src.need_website && src.website_url && src.website_source !== 'not_found') {\n  fields['site web'] = src.website_url;\n}\nif (src.need_note && ai.Notes) {\n  fields['Notes'] = String(ai.Notes).trim();\n}\nif (src.need_angle && ai.Angles) {\n  fields['Angles'] = String(ai.Angles).trim();\n}\nfields['Dernier contact'] = runDate;\n\nconst aEcrire = Object.keys(fields).filter(k => k !== 'id' && k !== 'Dernier contact').length > 0;\nif (!aEcrire) return null;\n\nreturn { json: fields };"
      },
