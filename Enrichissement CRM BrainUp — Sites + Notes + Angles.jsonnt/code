      "parameters": {
        "jsCode": "const out = [];\nfor (const it of $input.all()) {\n  const f = it.json;\n  if (!f.id || !f['Entreprise']) continue;\n  const site = String(f['site web'] || '').trim();\n  const notes = String(f['Notes'] || '').trim();\n  const angles = String(f['Angles'] || '').trim();\n  const need_website = site === '';\n  const need_note = notes === '';\n  const need_angle = angles === '' || angles === '0';\n  if (!need_website && !need_note && !need_angle) continue;\n  out.push({ json: {\n    record_id: f.id,\n    entreprise: String(f['Entreprise']).trim(),\n    email: String(f['Email'] || '').trim(),\n    site_existant: site,\n    need_website,\n    need_note,\n    need_angle\n  }});\n}\nreturn out;"
