    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const orig = $('Triage').item.json;\nconst hunter = $json;\n\nlet website_url = orig.site_existant || '';\nlet website_source = orig.site_existant ? 'existing' : 'not_found';\n\nif (!website_url) {\n  // Priorite 1 : domaine Hunter\n  const hunterDomain = hunter && hunter.data && hunter.data.domain;\n  if (hunterDomain) {\n    website_url = 'https://' + hunterDomain;\n    website_source = 'hunter';\n  }\n  // Priorite 2 : domaine de l'email (fallback)\n  else if (orig.email && orig.email.includes('@')) {\n    const domain = orig.email.split('@')[1];\n    if (domain && domain.includes('.') && !domain.includes('gmail') && !domain.includes('yahoo') && !domain.includes('hotmail') && !domain.includes('outlook')) {\n      website_url = 'https://' + domain;\n      website_source = 'email_domain';\n    }\n  }\n}\n\nreturn { json: {\n  record_id: orig.record_id,\n  entreprise: orig.entreprise,\n  email: orig.email,\n  site_existant: orig.site_existant,\n  need_website: orig.need_website,\n  need_note: orig.need_note,\n  need_angle: orig.need_angle,\n  website_url,\n  website_source\n}};\n"
      },
