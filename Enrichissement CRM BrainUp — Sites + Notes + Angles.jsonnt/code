    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const prev = $('Assembler donnees').item.json;\nconst html = $json.data || $json.body || '';\n\nconst strip = s => String(s||'')\n  .replace(/<script[\\s\\S]*?<\\/script>/gi,' ')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi,' ')\n  .replace(/<[^>]+>/g,' ')\n  .replace(/&nbsp;/g,' ').replace(/&amp;/g,'&').replace(/&[a-z]+;/gi,' ')\n  .replace(/\\s+/g,' ').trim();\n\nconst texte = (prev.website_source !== 'not_found') ? strip(html).slice(0, 4500) : '';\nconst low = texte.toLowerCase();\n\nconst signaux = {\n  estimation: /estimation|estimer|valeur.*bien/.test(low),\n  gestion_locative: /gestion locative|gerance/.test(low),\n  formulaire: /formulaire|nous contacter/.test(low),\n  rappel: /rappel gratuit|etre rappel/.test(low),\n  equipe: /notre equipe|nos collaborateurs/.test(low),\n  multi: /nos agences|plusieurs agences/.test(low),\n  transaction: /achat|vente|acheter|vendre/.test(low),\n  location: /location|louer|locataire/.test(low),\n  luxe: /prestige|luxe|haut de gamme/.test(low)\n};\n\nconst manquants = [];\nif (prev.need_note) manquants.push('Notes');\nif (prev.need_angle) manquants.push('Angles');\n\nconst ai_input = [\n  'ENTREPRISE : ' + prev.entreprise,\n  'SITE WEB : ' + (prev.website_url || 'non trouve'),\n  'SOURCE : ' + prev.website_source,\n  '',\n  'SIGNAUX : ' + JSON.stringify(signaux),\n  '',\n  'CHAMPS A GENERER : ' + (manquants.join(', ') || 'aucun'),\n  '',\n  '=== TEXTE DU SITE ===',\n  texte || '(site non accessible - base uniquement sur le nom de l entreprise et son secteur)',\n  '',\n  'Genere les champs manquants.'\n].join('\\n');\n\nreturn { json: { ...prev, texte_site: texte, signaux, ai_input } };"
      },
