        "mode": "runOnceForEachItem",
        "jsCode": "const src=$('Filtrer prospects dus').item.json;\nlet raw=($json.output!==undefined?$json.output:($json.text||''))+''; raw=raw.trim().replace(/^```[a-zA-Z]*\\s*/,'').replace(/\\s*```$/,'').trim();\nlet parsed; try{parsed=JSON.parse(raw);}catch(e){const m=raw.match(/\\{[\\s\\S]*\\}/);parsed=m?JSON.parse(m[0]):{Objet:'',Corps:raw};}\nconst objet=(parsed.Objet||parsed.objet||'').trim();\nconst corps=(parsed.Corps||parsed.corps||parsed.Email||'').trim();\nconst template=(parsed['Template choisi']||parsed.template||'').trim();\nconst corpsHtml=corps.replace(/\\n/g,'<br>');\nreturn {json:{id:src.recordId,'Objet email du jour':objet,'Corps email du jour':corps,'Corps HTML':corpsHtml,'Email destinataire':src.emailDestinataire,'Template email choisi':template,targetStep:src.targetStep,entreprise:src.entreprise||'',nom_complet:src.nomComplet||''}};\n"
