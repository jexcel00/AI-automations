    {
      "parameters": {
        "jsCode": "function clean(v){return(v===undefined||v===null)?'':String(v).replace(/[\\s​﻿]+/g,' ').trim();}\nfunction cleanEmail(e){return e.replace(/[\\s​﻿]/g,'').toLowerCase().replace(/\\.+$/,'');}\nfunction isValidEmail(e){return /^[^\\s@]+@[^\\s@]+\\.[^\\s@.]+$/.test(e);}\nconst DAY_LABEL={1:'Jour 1',2:'Jour 3',3:'Jour 7',4:'Jour 12'};\nconst EMAIL_NAME={1:'Email 1',2:'Email 2',3:'Email 3',4:'Email 4'};\nconst out=[];\nfor(const it of $input.all()){\n  const rec=it.json||{};const f=rec.fields||rec;const id=rec.id||f.id;\n  if(!id)continue;\n  if(f['A répondu']===true)continue;\n  const etape=Number(f['Étape']||0);\n  if(etape>=4)continue;\n  const emailRaw=clean(f['Email']);\n  const email=cleanEmail(emailRaw);\n  if(!email||email==='non trouvé'||!isValidEmail(email))continue;\n  const target=etape+1;\n  const nomComplet=clean(f['Nom complet']);const parts=nomComplet.trim().split(/\\s+/);\n  const prenom=parts[0]||'Bonjour';const entreprise=clean(f['Entreprise']);\n  const siteWeb=clean(f['site web']);const notes=clean(f['Notes']);const angles=clean(f['Angles']);\n  const lines=['ETAPE : '+EMAIL_NAME[target]+' ('+DAY_LABEL[target]+')','','CONTACT','- Prénom : '+(prenom||'?'),'- Nom complet : '+(nomComplet||'?'),'- Email : '+email,'- Entreprise : '+(entreprise||'?'),'- Site web : '+(siteWeb||'?'),'','ANALYSE CRM','- Notes : '+(notes||'non renseigné'),'- Angles : '+(angles||'non renseigné')];\n  out.push({json:{recordId:id,emailDestinataire:email,entreprise,nomComplet,website_url:siteWeb,targetStep:target,today:new Date().toISOString().slice(0,10),ai_input:lines.join('\\n')}});\n}\nreturn out;"
      },
