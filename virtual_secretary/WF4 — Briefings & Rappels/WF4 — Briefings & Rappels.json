    {
      "parameters": {
        "jsCode": "const events = $input.all().map(i => i.json).filter(e => e && e.summary).map(e => ({ summary: e.summary, start: (e.start && (e.start.dateTime || e.start.date)) || '' }));\nreturn [{ json: { events, events_count: events.length } }];"
      },
      "id": "wf4-cod-001",
      "name": "🧩 Agréger événements",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -16,
        0
