      "id": "wf4-gml-001",
      "name": "📧 Emails non lus",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        240,
        0
      ],
      "webhookId": "6b0628d9-dda5-42d5-bdb7-90e10ec3c41a",
      "credentials": {
        "gmailOAuth2": {
          "id": "BSKTkROxeWC8EZRQ",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const eventData = $('🧩 Agréger événements').first().json;\nconst emails = $input.all().map(i => i.json).filter(e => e && (e.subject || e.snippet));\nconst triggerData = $('🔄 Normaliser').first().json;\nconst timeOfDay = triggerData.time_of_day || 'morning';\nconst greeting = timeOfDay === 'evening' ? '🌙 Briefing du soir' : '☀️ Briefing du matin';\nconst eventsText = eventData.events_count > 0 ? eventData.events.map(e => '• ' + e.summary + (e.start ? ' — ' + e.start.substring(11, 16) : '')).join('\\n') : 'Aucun événement prévu';\nconst emailsText = emails.length > 0 ? emails.map(e => '• ' + (e.subject || e.snippet || 'Sans objet')).join('\\n') : 'Aucun email non lu';\nconst context = greeting + '\\n\\nÉVÉNEMENTS DU JOUR:\\n' + eventsText + '\\n\\nEMAILS NON LUS (' + emails.length + '):\\n' + emailsText;\nreturn [{ json: { context, time_of_day: timeOfDay, events_count: eventData.events_count, emails_count: emails.length } }];"
      },
      "id": "wf4-cod-002",
      "name": "🧩 Compiler contexte",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
